# Postgres
POSTGRES_DB=iknos
POSTGRES_USER=iknos
POSTGRES_PASSWORD=change-me

# Connection string used by the API and by Alembic
DATABASE_URL=postgresql+asyncpg://iknos:change-me@postgres:5432/iknos

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# LLM (vLLM OpenAI-compatible). LLM_MODEL is the served model id; required before any
# propositionization call. LLM_CALL_TIMEOUT_S is the hard wall-clock deadline for one call
# *including* retries (G1.17 R5) — a backstop so a hung endpoint cannot hold a concurrency
# permit forever; generous by default, above the tenacity backoff ceiling.
LLM_BASE_URL=http://192.168.0.247:8000/v1
LLM_MODEL=
LLM_CALL_TIMEOUT_S=180

# Independent verifier for extract-then-verify (G1.4). Use a DIFFERENT model family from
# LLM_MODEL to cut correlated error (§13). Leave LLM_VERIFIER_MODEL empty to disable
# verification (faithfulness/provisional stay null). base_url may equal LLM_BASE_URL (same
# vLLM, different model) or point at a separate server.
LLM_VERIFIER_BASE_URL=http://192.168.0.247:8000/v1
LLM_VERIFIER_MODEL=

# Multi-sample extraction (G1.3) — the consistency half of faithfulness. Number of times the
# extractor is sampled per span; stable extractions get high agreement, unstable ones are
# flagged provisional. Default 1 = single-pass (current behavior, agreement no-op). Raising it
# requires a temperature>0 sampling regime. PROP_AGREEMENT_THRESHOLD is the cosine cutoff at
# which two extractions count as the same claim.
LLM_EXTRACT_SAMPLES=1
PROP_AGREEMENT_THRESHOLD=0.86

# Stage 0 document parse front-end (G1.0). MinerU (AGPL-3.0) runs as a separate hosted
# service behind PARSER_BASE_URL — the copyleft stops at the service edge, like the LLM.
# Leave PARSER_BASE_URL empty to use the identity (null) parser: plain text in, no page
# geometry (Span.layout stays null) — a first-class mode, not degradation. PARSER_KIND
# selects the client when a base URL is set: "null" (default) or "mineru". PARSER_TIMEOUT_S
# is the per-request wall-clock budget — generous because OCR of a scanned document is slow.
PARSER_BASE_URL=
PARSER_KIND=null
PARSER_TIMEOUT_S=300

# Prod-only: external Traefik network and routing
# TRAEFIK_NETWORK=web
# API_DOMAIN=iknos.example.com
